<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
    <link rel="stylesheet" href="/styles/panel-admin.css">

    <title>Panel Administrador - Akalia</title>
</head>

<body class="bg-blanco">
  
  <!-- Admin Navbar -->
  <%- include('../partials/admin/admin-navbar') %>

  <div class="admin-container">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <main class="container-fluid admin-content mt-5">
      <div class="row">
        <div class="col-12">
          <!-- Header -->
          <div class="admin-header text-center mb-4">
            <h1 class="admin-title text-color-vinotinto mb-1">Panel Administrador</h1>
            <p class="text-color-verde mb-0">Gestión administrativa de la plataforma Akalia</p>
          </div>

          <!-- Dashboard Cards -->
          <div class="row mb-4">
            <div class="col-xl-3 col-lg-6 col-md-6 col-12 mb-3">
              <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h3 class="stat-number text-color-vinotinto mb-1" id="usersCount">999</h3>
                    <p class="stat-label text-muted mb-0">Usuarios</p>
                  </div>
                  <div class="stat-icon bg-color-vinotinto text-white p-3 rounded">
                    <i class="fa-solid fa-users"></i>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-xl-3 col-lg-6 col-md-6 col-12 mb-3">
              <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h3 class="stat-number text-color-terracota mb-1" id="emprendimientosCount">99</h3>
                    <p class="stat-label text-muted mb-0">Emprendimientos</p>
                  </div>
                  <div class="stat-icon bg-color-terracota text-white p-3 rounded">
                    <i class="fa-solid fa-store"></i>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-xl-3 col-lg-6 col-md-6 col-12 mb-3">
              <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h3 class="stat-number text-color-verde mb-1" id="pedidosCount">201</h3>
                    <p class="stat-label text-muted mb-0">Pedidos</p>
                  </div>
                  <div class="stat-icon bg-color-verde text-white p-3 rounded">
                    <i class="fa-solid fa-box"></i>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-xl-3 col-lg-6 col-md-6 col-12 mb-3">
              <div class="card stat-card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h3 class="stat-number text-color-vinotinto mb-1" id="comisionesCount">$5.558</h3>
                    <p class="stat-label text-muted mb-0">Comisiones</p>
                  </div>
                  <div class="stat-icon bg-color-vinotinto text-white p-3 rounded">
                    <i class="fa-solid fa-dollar-sign"></i>
                  </div>
                </div>
              </div>
            </div>
          <!-- Charts Section -->
          <div class="row mb-4">
            <!-- Sales/Orders Chart -->
            <div class="col-lg-8 col-md-12 mb-4">
              <div class="card h-100">
                <div class="card-header bg-color-vinotinto text-white">
                  <h5 class="card-title mb-0">Pedidos/Ventas</h5>
                </div>
                <div class="card-body">
                  <div class="chart-placeholder" style="height: 350px; background: linear-gradient(45deg, #f8f9fa 25%, transparent 25%), linear-gradient(-45deg, #f8f9fa 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #f8f9fa 75%), linear-gradient(-45deg, transparent 75%, #f8f9fa 75%); background-size: 20px 20px; background-position: 0 0, 0 10px, 10px -10px, -10px 0px; display: flex; align-items: center; justify-content: center; border: 2px dashed #dee2e6;">
                    <div class="text-muted text-center">
                      <i class="fa-solid fa-chart-line fa-3x mb-3"></i>
                      <h6>Gráfico de Ventas/Pedidos</h6>
                      <small>Vista previa del diseño</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Categories Distribution Chart -->
            <div class="col-lg-4 col-md-12 mb-4">
              <div class="card h-100">
                <div class="card-header bg-color-terracota text-white">
                  <h5 class="card-title mb-0">Distribución por Categorías</h5>
                </div>
                <div class="card-body">
                  <div class="chart-placeholder" style="height: 350px; background: linear-gradient(45deg, #f8f9fa 25%, transparent 25%), linear-gradient(-45deg, #f8f9fa 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #f8f9fa 75%), linear-gradient(-45deg, transparent 75%, #f8f9fa 75%); background-size: 20px 20px; background-position: 0 0, 0 10px, 10px -10px, -10px 0px; display: flex; align-items: center; justify-content: center; border: 2px dashed #dee2e6;">
                    <div class="text-muted text-center">
                      <i class="fa-solid fa-chart-pie fa-3x mb-3"></i>
                      <h6>Gráfico de Categorías</h6>
                      <small>Distribución por categorías</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Reports Section -->
          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-header bg-color-verde text-white d-flex justify-content-between align-items-center">
                  <h5 class="card-title mb-0">Reportes Recientes</h5>
                  <button class="btn btn-light btn-sm">Ver todos</button>
                </div>
                <div class="card-body p-0">
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th class="d-none d-md-table-cell">Fecha</th>
                          <th>ID Reporte</th>
                          <th class="d-none d-sm-table-cell">Usuario</th>
                          <th>Tipo</th>
                          <th>Estado</th>
                          <th>Acciones</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td class="d-none d-md-table-cell">15/03/2024</td>
                          <td><strong>RPT001</strong></td>
                          <td class="d-none d-sm-table-cell">usuario1@email.com</td>
                          <td><span class="badge bg-info">Usuario</span></td>
                          <td><span class="badge bg-success">Activo</span></td>
                          <td>
                            <div class="btn-group" role="group">
                              <button class="btn btn-sm btn-outline-primary" title="Ver">
                                <i class="fa-solid fa-eye"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-secondary" title="Editar">
                                <i class="fa-solid fa-edit"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                        <tr>
                          <td class="d-none d-md-table-cell">14/03/2024</td>
                          <td><strong>RPT002</strong></td>
                          <td class="d-none d-sm-table-cell">emprendedor@email.com</td>
                          <td><span class="badge bg-success">Emprendimiento</span></td>
                          <td><span class="badge bg-warning">Pendiente</span></td>
                          <td>
                            <div class="btn-group" role="group">
                              <button class="btn btn-sm btn-outline-primary" title="Ver">
                                <i class="fa-solid fa-eye"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-secondary" title="Editar">
                                <i class="fa-solid fa-edit"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                        <tr>
                          <td class="d-none d-md-table-cell">13/03/2024</td>
                          <td><strong>RPT003</strong></td>
                          <td class="d-none d-sm-table-cell">cliente@email.com</td>
                          <td><span class="badge bg-warning">Pedido</span></td>
                          <td><span class="badge bg-secondary">Resuelto</span></td>
                          <td>
                            <div class="btn-group" role="group">
                              <button class="btn btn-sm btn-outline-primary" title="Ver">
                                <i class="fa-solid fa-eye"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-secondary" title="Editar">
                                <i class="fa-solid fa-edit"></i>
                              </button>
                              <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
        </div>
      </div>
    </main>
  </div>

  <script src="/lib/js/bootstrap.bundle.min.js"></script>
  
</body>
</html>